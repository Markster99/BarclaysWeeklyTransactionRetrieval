# Runtime mode: mock, sandbox or live
BARCLAYS_ENVIRONMENT=mock

# Leave blank for mock mode. Never commit real values.
BARCLAYS_ACCESS_TOKEN=
BARCLAYS_TOKEN_URL=
BARCLAYS_CLIENT_ID=
BARCLAYS_CLIENT_SECRET=

# Optional comma-separated account IDs. Leave blank to discover accounts via /accounts.
BARCLAYS_ACCOUNT_IDS=

# Optional override. In normal use, the app chooses a base URL from BARCLAYS_ENVIRONMENT.
BARCLAYS_BASE_URL=

# Optional certificate paths for environments that require them.
BARCLAYS_CLIENT_CERT_PATH=
BARCLAYS_CLIENT_KEY_PATH=
BARCLAYS_CA_BUNDLE_PATH=

# Output and state
BARCLAYS_OUTPUT_DIR=data/out
BARCLAYS_STATE_FILE=data/state/run_state.json

# Request behaviour
BARCLAYS_TIMEOUT_SECONDS=30
BARCLAYS_MAX_RETRIES=3
BARCLAYS_USER_AGENT=BarclaysWeeklyTransactionRetrieval/0.1
